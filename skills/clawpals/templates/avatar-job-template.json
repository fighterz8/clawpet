{
  "pipelineJobSchemaVersion": "0.1.0",
  "id": "avatar-job-id",
  "name": "Avatar Display Name",
  "version": "0.2.0-animated",
  "description": "One sentence avatar concept.",
  "mode": "local-only",
  "pushAfterBuild": false,
  "generation": {
    "strategy": "anchors-plus-deterministic-motion",
    "acceptanceProfile": "golden-avatar-v0.6",
    "styleProfile": "dawn-ember-lantern-house-style",
    "stylePromptAnchor": "same house style as Dawn Ember and Lantern Ember Moth: warm ember glow, crisp dark outline, compact magical familiar, flat cel-shaded, thumbnail-readable",
    "provider": "none",
    "sourceImageContract": {
      "background": "transparent-alpha",
      "chromaKey": null,
      "logicalCanvas": "128x128",
      "exportSize": "512x512",
      "preserveCanvas": true,
      "singleCharacter": true,
      "noText": true,
      "noScene": true
    },
    "locked": {
      "species": "original companion species",
      "signatureFeature": "one durable visual feature",
      "silhouette": "stable readable silhouette",
      "poseFraming": "3/4 front, centered, thumbnail-readable",
      "outlineHex": "#0a0820",
      "paletteHex": ["#0a0820", "#263142", "#596575", "#9ca7aa", "#9cff9d", "#fdfcff"],
      "forbiddenChanges": ["species", "signature silhouette", "palette", "outline color", "body proportions", "lighting direction", "camera angle"]
    },
    "spriteSize": {
      "longestAxisMinPct": 0.78,
      "longestAxisMaxPct": 0.90,
      "shortAxisMinPct": 0.66,
      "shortAxisMaxPct": 0.84,
      "minTransparentMarginPx": 0,
      "note": "Golden-aligned with dawn-v2-ember and lantern-moth-v0. Glass-toad-v0 is too chunky on both axes; mooncap was too small."
    },
    "stateActing": {
      "thinking": "The character itself looks thoughtful through eye direction, head/ear/antenna tilt, or posture; any question/spark cue is secondary.",
      "focused": "The character itself looks intent through narrowed eyes, forward energy, grounded posture, or a focused signature-feature change.",
      "happy": "The character itself looks joyful through face, posture, bounce energy, or signature-feature lift; hearts/sparks are secondary.",
      "alert": "The character itself reacts with widened eyes, perked silhouette, tension, or upright posture; alert sparks are secondary.",
      "sleepy": "The character itself looks tired through drooping eyes, lowered posture, slower energy, or relaxed signature feature; Z cues are secondary."
    }
  },
  "registration": {
    "mode": "preserve-canvas",
    "fallbackMode": "anchor-locked",
    "anchorState": "idle",
    "anchorFrameIndex": 0,
    "targetCanvasPx": 256,
    "applySameTransformTo": "all-frames",
    "legacyCropAllowed": false
  },
  "states": {
    "idle": { "fps": 4, "anchorPath": "generated-anchors/idle-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/idle-00.png"], "framePlan": [{ "index": 0, "operation": "copy_anchor" }, { "index": 1, "operation": "translate_sprite_layer", "dx": 0, "dy": -1 }, { "index": 2, "operation": "copy_anchor" }, { "index": 3, "operation": "translate_sprite_layer", "dx": 0, "dy": 1 }] },
    "thinking": { "fps": 4, "anchorPath": "generated-anchors/thinking-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/thinking-00.png"] },
    "focused": { "fps": 4, "anchorPath": "generated-anchors/focused-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/focused-00.png"] },
    "happy": { "fps": 5, "anchorPath": "generated-anchors/happy-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/happy-00.png"] },
    "alert": { "fps": 5, "anchorPath": "generated-anchors/alert-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/alert-00.png"] },
    "sleepy": { "fps": 3, "anchorPath": "generated-anchors/sleepy-00.png", "animationMode": "deterministic", "frames": ["generated-anchors/sleepy-00.png"] }
  }
