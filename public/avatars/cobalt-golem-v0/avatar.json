{
  "schemaVersion": "0.5.0",
  "name": "Cobalt Golem",
  "version": "0.6.0-official-candidate",
  "description": "Cobalt Golem: chibi cobalt rune-golem familiar in the Dawn Ember / Lantern Ember Moth v2 house style; official Clawpals candidate.",
  "defaultState": "idle",
  "states": {
    "idle": {
      "frames": [
        "frames/idle-00.png",
        "frames/idle-01.png",
        "frames/idle-02.png",
        "frames/idle-03.png"
      ],
      "fps": 4,
      "loop": true,
      "fallbackAsset": "assets/idle.png"
    },
    "thinking": {
      "frames": [
        "frames/thinking-00.png",
        "frames/thinking-01.png",
        "frames/thinking-02.png",
        "frames/thinking-03.png"
      ],
      "fps": 4,
      "loop": true,
      "fallbackAsset": "assets/thinking.png"
    },
    "focused": {
      "frames": [
        "frames/focused-00.png",
        "frames/focused-01.png",
        "frames/focused-02.png",
        "frames/focused-03.png"
      ],
      "fps": 4,
      "loop": true,
      "fallbackAsset": "assets/focused.png"
    },
    "happy": {
      "frames": [
        "frames/happy-00.png",
        "frames/happy-01.png",
        "frames/happy-02.png",
        "frames/happy-03.png"
      ],
      "fps": 5,
      "loop": true,
      "fallbackAsset": "assets/happy.png"
    },
    "alert": {
      "frames": [
        "frames/alert-00.png",
        "frames/alert-01.png",
        "frames/alert-02.png",
        "frames/alert-03.png"
      ],
      "fps": 5,
      "loop": true,
      "fallbackAsset": "assets/alert.png"
    },
    "sleepy": {
      "frames": [
        "frames/sleepy-00.png",
        "frames/sleepy-01.png",
        "frames/sleepy-02.png",
        "frames/sleepy-03.png"
      ],
      "fps": 4,
      "loop": true,
      "fallbackAsset": "assets/sleepy.png"
    }
  },
  "build": {
    "registration": {
      "mode": "preserve-canvas",
      "fallbackMode": "anchor-locked",
      "anchorState": "idle",
      "anchorFrameIndex": 0,
      "targetCanvasPx": 256,
      "applySameTransformTo": "all-frames",
      "legacyCropAllowed": false
    },
    "sourceImageContract": {
      "background": "chroma-green",
      "chromaKey": "#10EA6D",
      "logicalCanvas": "128x128",
      "exportSize": "1024x1024",
      "preserveCanvas": true,
      "singleCharacter": true,
      "noText": true,
      "noScene": true
    },
    "registrationTransform": null
  }
}
