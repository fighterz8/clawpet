{
  "schemaVersion": "0.1.0",
  "name": "Pip",
  "version": "0.1.0",
  "description": "Cyan slime familiar — second test avatar to validate the multi-avatar pipeline.",
  "defaultState": "idle",
  "states": {
    "idle":     { "asset": "assets/idle.png",     "animation": "breathe" },
    "thinking": { "asset": "assets/thinking.png", "animation": "bob" },
    "focused":  { "asset": "assets/focused.png",  "animation": "breathe" },
    "happy":    { "asset": "assets/happy.png",    "animation": "bounce" },
    "alert":    { "asset": "assets/alert.png",    "animation": "shake" },
    "sleepy":   { "asset": "assets/sleepy.png",   "animation": "slowBlink" }
  }
}
