{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clawpals",
  "version": "0.6.0",
  "identifier": "ai.openclaw.clawpals",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/onboard.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Clawpals",
        "label": "main",
        "url": "/onboard.html",
        "width": 820,
        "height": 560,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": false,
        "center": true
      },
      {
        "title": "Clawpals",
        "label": "pet",
        "url": "/overlay.html",
        "width": 360,
        "height": 320,
        "minWidth": 360,
        "minHeight": 320,
        "maxWidth": 360,
        "maxHeight": 320,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "tooltip": "Clawpals",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
