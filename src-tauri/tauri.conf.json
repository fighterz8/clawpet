{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clawpet",
  "version": "0.1.0",
  "identifier": "ai.openclaw.clawpet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173/onboard.html",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Clawpet",
        "label": "main",
        "url": "/onboard.html",
        "width": 560,
        "height": 720,
        "minWidth": 520,
        "minHeight": 640,
        "resizable": true,
        "maximizable": false,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/32x32.png",
      "tooltip": "Clawpet",
      "menuOnLeftClick": false
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
